node_modules
dist
.DS_Store
server/public
vite.config.ts.*
*.tar.gz
release/

# Claude Code local state — per-machine settings, session locks, etc.
# Not part of PDR source. .claude/agents and .claude/commands ARE
# tracked (those are project-shared instructions); the rest is local.
.claude/worktrees/
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/projects/
.claude/cache/

# Local secrets — Cloudflare R2 credentials, signing certs, etc.
# Never commit these. See .env.example for the expected shape.
.env
.env.local
.env.*.local

# Wrangler local cache (R2 simulator state, dev cache).
# Recreated automatically on next `wrangler dev` / `wrangler deploy`.
.wrangler/

# Local debugging stdout from `npx electron .` runs. Captured by the
# launch wrapper so log output is queryable without keeping the
# console open. Per-run, never committed.
electron-stdout.log

# Per-session scratch directory for ad-hoc diagnostic scripts
# (DB-forensics .cjs files, throwaway better-sqlite3 installs, etc).
# Never part of the shipped product or the source tree.
.scratch/
