# Photo Date Rescue — local secrets template.
#
# Copy this file to `.env` (in the repo root) and fill in the real
# values. `.env` is gitignored so your secrets stay local. Never
# commit anything that has real credentials.
#
# These values are needed by:
#   - script/release.ts (Phase C: uploads the signed NSIS installer
#     and latest.yml to the Cloudflare R2 bucket)
#   - electron-builder publish (when run with --publish always)
#
# How to obtain:
#   1. Cloudflare dashboard -> R2 Object Storage -> Manage R2 API Tokens
#   2. Create User API Token, scope: Object Read & Write, bucket:
#      pdr-updates, TTL: Forever
#   3. Copy the four values shown on the one-time confirmation screen.

# 32-char hex string. Visible at any time on the R2 page (right
# sidebar) or as the subdomain of the S3 endpoint URL.
R2_ACCOUNT_ID=

# Shorter ~32-char string. Shown ONCE on the token-creation screen.
# Cannot be recovered — revoke and recreate the token if lost.
R2_ACCESS_KEY_ID=

# Long ~64-char string. Shown ONCE on the token-creation screen.
# Cannot be recovered — revoke and recreate the token if lost.
R2_SECRET_ACCESS_KEY=

# Bucket name. Should be `pdr-updates` unless you've renamed it.
R2_BUCKET=pdr-updates

# S3-compatible endpoint URL. Format:
#   https://<account-id>.r2.cloudflarestorage.com
# Visible on R2 -> bucket -> Settings -> S3 API.
R2_ENDPOINT=
